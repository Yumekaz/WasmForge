{
  "rewrites": [
    {
      "source": "/ide",
      "destination": "/"
    },
    {
      "source": "/ide/:path*",
      "destination": "/"
    },
    {
      "source": "/test",
      "destination": "/"
    },
    {
      "source": "/test/:path*",
      "destination": "/"
    },
    {
      "source": "/teacher",
      "destination": "/"
    },
    {
      "source": "/teacher/:path*",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ]
}
